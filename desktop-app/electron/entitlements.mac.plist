<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow the app to send Apple Events (for opening System Preferences) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- Allow read/write access to user-selected files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Allow read access to Downloads folder -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- Allow outgoing network connections (for cloud sync) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow spawning child processes (for Python bridge) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
